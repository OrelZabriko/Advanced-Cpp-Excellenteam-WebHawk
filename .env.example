# Copy this file to .env and fill in real values:  cp .env.example .env
# .env is git-ignored - never commit real secrets.
# Lines starting with # are comments and are skipped by the loader
# (see services/shared/EnvLoader.h). Do NOT put comments at the end of a
# line - only whole-line comments are supported.

# --- Database (used by every service: users, security-engine, backend-registry) ---
# 127.0.0.1 = every service runs natively (WSL), not inside Docker.
# Use "postgres" instead if a service runs inside Docker Compose and needs
# to reach the "postgres" container by its service name.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=webhawk

# --- JWT (used only by the users service) ---
JWT_SECRET=change_this_secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_SECS=86400

# --- Rate limiting (used only by the security-engine service) ---
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECS=60