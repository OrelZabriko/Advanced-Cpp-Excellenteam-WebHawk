# Copy this file to .env and fill in real values:  cp .env.example .env
# .env is git-ignored - never commit real secrets.
# Lines starting with # are comments and are skipped by the loader
# (see services/shared/EnvLoader.h). Do NOT put comments at the end of a
# line - only whole-line comments are supported.

# --- Database (used by every service: users, security-engine, backend-registry) ---
# "postgres" = the Docker Compose service name for Postgres - use this when
# running via `docker compose up` (the normal way to run this project).
# If you ever run a service natively (outside Docker, straight on WSL) for
# debugging, override this to 127.0.0.1 in your local .env for that session.
DB_HOST=postgres
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=webhawk

# --- JWT (used only by the users service) ---
JWT_SECRET=change_this_secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_SECS=86400

# --- Rate limiting (used only by the security-engine service) ---
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECS=60