{
  "info": {
    "name": "WebHawk - Security Engine Tests",
    "description": "Test collection for Nadav's Security Engine (POST /analyze). Based on the example payloads from WebHawk_Build_Plan.docx Step 6.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "SQLi Attack - should be BLOCKED",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"endpoint\": \"/api/users\",\n  \"method\": \"GET\",\n  \"ip\": \"203.0.113.5\",\n  \"headers\": {\n    \"user-agent\": \"Mozilla/5.0\"\n  },\n  \"query_params\": {\n    \"search\": \"' OR 1=1 --\"\n  },\n  \"path_params\": {},\n  \"body\": {}\n}"
        },
        "url": {
          "raw": "http://localhost:8081/analyze",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8081",
          "path": ["analyze"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 403 Forbidden', function () {",
              "    pm.response.to.have.status(403);",
              "});",
              "pm.test('Response says allowed=false', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.allowed).to.eql(false);",
              "});",
              "pm.test('Attack type is sqli', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.attack_type).to.eql('sqli');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
